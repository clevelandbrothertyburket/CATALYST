# Neon Postgres connection string (Vercel → Storage → Neon gives you this).
# Local dev: copy this file to .env.local and fill in.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Secret used to sign session cookies. Generate one with:  openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"


# Initial admin password — used ONLY by `npm run db:seed` to set the first
# admin's password_hash. Not read at runtime. Set it in your shell when seeding,
# don't commit a real value here. Example:
#   DATABASE_URL="..." ADMIN_PASSWORD='YourStrongPassword' npm run db:seed
ADMIN_PASSWORD=""
# Optional overrides for the seeded admin (defaults: tburket@clevelandbrothers.com / "Ty Burket")
ADMIN_EMAIL=""
ADMIN_NAME=""

# Email invites — sent via a Zapier Catch Hook (the Zap sends from your real
# Outlook/Gmail, so no domain or DMARC setup is needed). Without this, the
# "Invite user" flow still creates the account but does NOT send an email.
ZAPIER_EMAIL_WEBHOOK_URL=""
# Base URL used in the invite's sign-in link (defaults to the request origin).
APP_URL=""

# Weekly report (optional). The /api/cron/weekly-report job (see vercel.json,
# Mondays 13:00 UTC) POSTs a digest here for a second Zap to email your team.
ZAPIER_REPORT_WEBHOOK_URL=""
# Protects the cron endpoint — Vercel Cron sends this as a Bearer token.
CRON_SECRET=""

# ClickUp — creates a task when a campaign code request is approved.
# Token goes RAW in the Authorization header (no "Bearer"); pk_ must be lowercase.
CLICKUP_TOKEN=""            # personal token (pk_...). CLICKUP_API_KEY also accepted.
CLICKUP_LIST_ID=""          # the List tasks go into (numeric, from the list URL)
CLICKUP_ASSIGNEE_ID=""      # optional — overrides default assignee (Chris Lauffer 81440323)
CLICKUP_SPRINT_TAG=""       # optional — current-sprint tag (default "current sprint")

# Bitly — optional. When set, Link Hub also creates a Bitly short link and pulls
# its analytics (clicks, geo, devices, referrers) into Catalyst so the team
# doesn't have to switch between Bitly and Catalyst.
BITLY_TOKEN=""             # Bitly Generic Access Token (Settings → API)
BITLY_GROUP_GUID=""        # optional — defaults to your default group
