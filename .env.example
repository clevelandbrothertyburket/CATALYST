# Neon Postgres connection string (Vercel → Storage → Neon gives you this).
# Local dev: copy this file to .env.local and fill in.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Secret used to sign session cookies. Generate one with:  openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Bitly API token (Account Settings → API in Bitly). The whole tool shortens
# through this one account. Keep it server-side only — never commit it.
BITLY_TOKEN="paste-your-NEW-bitly-token-here"

# Initial admin password — used ONLY by `npm run db:seed` to set the first
# admin's password_hash. Not read at runtime. Set it in your shell when seeding,
# don't commit a real value here. Example:
#   DATABASE_URL="..." ADMIN_PASSWORD='YourStrongPassword' npm run db:seed
ADMIN_PASSWORD=""
# Optional overrides for the seeded admin (defaults: tburket@clevelandbrothers.com / "Ty Burket")
ADMIN_EMAIL=""
ADMIN_NAME=""

# Email invites — set ONE provider key. Without any, the "Invite user" flow
# still creates the account but does NOT send an email.
#
# Brevo (no domain needed — verify ONE sender email; free 300/day). Recommended.
BREVO_API_KEY=""
# SendGrid (no domain needed — "Single Sender Verification"; free 100/day).
SENDGRID_API_KEY=""
# Resend (needs a verified DOMAIN to email real recipients).
RESEND_API_KEY=""
# The verified sender. For Brevo/SendGrid this MUST be the address you verified,
# e.g. "Catalyst <you@clevelandbrothers.com>".
EMAIL_FROM=""
# Base URL used in the invite's sign-in link (defaults to the request origin).
APP_URL=""
